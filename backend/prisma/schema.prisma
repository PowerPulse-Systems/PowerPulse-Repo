generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("Viewer") // Admin, Facility Manager, Technician, Viewer
  createdAt    DateTime @default(now())
  devices      Device[]
}

model Building {
  id        String   @id @default(uuid())
  name      String
  address   String?
  panels    Panel[]
}

model Panel {
  id         String    @id @default(uuid())
  name       String
  buildingId String
  building   Building  @relation(fields: [buildingId], references: [id])
  breakers   Breaker[]
}

model Device {
  id              String    @id @default(uuid())
  macAddress      String    @unique
  type            String    // Main board, Sensor node, Switch node
  name            String?
  firmwareVersion String?
  onlineStatus    Boolean   @default(false)
  lastSeen        DateTime?
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  breakers        Breaker[]
  dashboard       Dashboard?
  createdAt       DateTime  @default(now())
}

model Breaker {
  id             String          @id @default(uuid())
  label          String
  phase          String?
  panelId        String
  deviceId       String
  panel          Panel           @relation(fields: [panelId], references: [id])
  device         Device          @relation(fields: [deviceId], references: [id])
  energyReadings EnergyReading[]
}

model EnergyReading {
  id           String   @id @default(uuid())
  breakerId    String
  periodStart  Int
  periodEnd    Int
  energyWh     Float
  avgPowerW    Float
  peakPowerW   Float
  createdAt    DateTime @default(now())
  breaker      Breaker  @relation(fields: [breakerId], references: [id])
}

model Alert {
  id           String   @id @default(uuid())
  severity     String
  message      String
  acknowledged Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model AutomationRule {
  id        String  @id @default(uuid())
  condition String
  action    String
  enabled   Boolean @default(true)
}

model Dashboard {
  id        String   @id @default(uuid())
  deviceId  String   @unique
  device    Device   @relation(fields: [deviceId], references: [id])
  widgets   Widget[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Widget {
  id          String   @id @default(uuid())
  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  type        String   // "card" initially, future: "graph", "alerts"
  title       String
  metric      String   // "energy_usage", "current_load", "power", "voltage"
  breakers    String[] // array of breaker IDs
  aggregation String   @default("sum") // "sum", future: "average", "max", "min"
  timePreset  String?  // "today", "last_24_hours", "this_week", "this_month", "this_year"
  customHours Int?     // for custom duration
  customStart DateTime? // for custom range
  customEnd   DateTime? // for custom range
  size        String   @default("small") // "small", "medium", "large"
  position    Int      @default(0)
  config      Json?    // extensible config for future widget types
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
